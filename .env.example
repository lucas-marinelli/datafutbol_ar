# Plantilla de variables de entorno — copiá este archivo a `.env` y completá
# con tus claves. NUNCA subir `.env` al repo (está en .gitignore).

# ── API-Football (api-sports.io) ────────────────────────────
# Plan free: 100 req/día. Sirve para fixtures, lineups en vivo.
API_FOOTBALL_KEY=

# ── Otras APIs futuras ──────────────────────────────────────
# OpenAI key si usamos para generar captions
# OPENAI_API_KEY=

# Twitter/X API si decidimos automatizar publicaciones
# X_API_KEY=
# X_API_SECRET=
# X_BEARER_TOKEN=

# ── Paths opcionales ────────────────────────────────────────
# Por default los scripts usan paths relativos al repo. Si querés
# overridear, definir acá:
# DATA_DIR=
# OUTPUTS_DIR=
